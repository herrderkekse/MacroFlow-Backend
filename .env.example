# Copy to .env and edit. All values shown are the defaults unless noted.

# Statically-provisioned users (in addition to any self-registered accounts).
# Give each device owner one "username:password" pair. Separate multiple users
# with commas. REQUIRED — the server refuses to start with no users.
USERS=alice:change-me

# Self-service signup via POST /api/v1/auth/register (bcrypt-hashed accounts in
# the database). Set to false to lock down registration once your accounts
# exist; login and existing accounts keep working. Default: true.
# ALLOW_SIGNUP=true

# Alternatively, point at a file with one "user:pass" per line (Docker secrets).
# Lines starting with '#' are ignored. USERS and USERS_FILE are merged.
# USERS_FILE=/run/secrets/macroflow_users

# Listen port (inside the container).
PORT=8080

# SQLite database file. In Docker this defaults to /data/macroflow.db; mount a
# volume at /data so the log survives restarts.
# DB_PATH=./data/macroflow.db

# Max accepted request body. Push payloads can carry base64 progress photos,
# so keep this comfortably above 20 MB. Default 32 MiB.
# MAX_BODY_BYTES=33554432

# Max page size a client may request on pull (server caps 'limit'). Default 1000.
# MAX_LIMIT=1000

# Per-user storage cap in bytes for the stored change log (mostly base64
# photos). A push that would leave a user over the cap is rejected with 507 and
# stores nothing; delete-only batches are always allowed so users can free up
# space. 0 (the default) means unlimited. Example below caps each user at 50 MB.
# MAX_USER_BYTES=52428800
